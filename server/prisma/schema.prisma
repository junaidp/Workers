generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
  TRADESMAN
}

enum JobStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
  CANCELLED
  TIMEOUT
}

enum TradesmanBadge {
  VERIFIED
  PLATINUM
  GOLD
  SILVER
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id                 String   @id @default(cuid())
  email              String?  @unique
  password           String?
  role               UserRole
  firstName          String?
  lastName           String?
  whatsapp           String?
  mobile             String   @unique
  countryCode        String   @default("+92")
  isEmailVerified    Boolean  @default(true)
  isWhatsappVerified Boolean  @default(true)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  customer  Customer?
  tradesman Tradesman?
  admin     Admin?

  @@index([email])
  @@index([mobile])
}

model Customer {
  id       String  @id @default(cuid())
  userId   String  @unique
  fullName String
  city     String
  area     String
  landline String?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs    Job[]
  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tradesman {
  id                 String             @id @default(cuid())
  userId             String             @unique
  tradesmanId        String             @unique
  businessName       String
  businessAddress    String
  buildingNumber     String?
  street             String?
  town               String
  city               String
  country            String             @default("Pakistan")
  description        String             @db.Text
  cnicNumber         String
  cnicImage          String
  proofOfAddress     String?
  profilePicture     String
  tradeLicense       String?
  landline           String?
  website            String?
  badge              TradesmanBadge     @default(VERIFIED)
  verificationStatus VerificationStatus @default(PENDING)
  prepaidCredit      Int                @default(2)
  totalJobsCompleted Int                @default(0)
  rating             Float              @default(0)
  reviewCount        Int                @default(0)
  isApproved         Boolean            @default(false)
  isVisible          Boolean            @default(true)

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  services           TradesmanService[]
  portfolioImages    PortfolioImage[]
  certifications     Certification[]
  jobResponses       JobResponse[]
  reviews            Review[]
  creditTransactions CreditTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tradesmanId])
  @@index([city])
  @@index([isApproved])
  @@index([verificationStatus])
}

model Admin {
  id     String @id @default(cuid())
  userId String @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String? @db.Text
  image       String?
  isActive    Boolean @default(true)
  order       Int     @default(0)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model Service {
  id          String  @id @default(cuid())
  categoryId  String
  name        String
  slug        String  @unique
  description String? @db.Text
  image       String?
  parentId    String?
  level       Int     @default(1)
  isActive    Boolean @default(true)
  order       Int     @default(0)

  category ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  parent   Service?        @relation("ServiceHierarchy", fields: [parentId], references: [id])
  children Service[]       @relation("ServiceHierarchy")

  tradesmanServices TradesmanService[]
  jobServices       JobService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([categoryId])
  @@index([parentId])
}

model TradesmanService {
  id          String @id @default(cuid())
  tradesmanId String
  serviceId   String

  tradesman Tradesman @relation(fields: [tradesmanId], references: [id], onDelete: Cascade)
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([tradesmanId, serviceId])
  @@index([tradesmanId])
  @@index([serviceId])
}

model PortfolioImage {
  id          String  @id @default(cuid())
  tradesmanId String
  imageUrl    String
  caption     String?

  tradesman Tradesman @relation(fields: [tradesmanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tradesmanId])
}

model Certification {
  id          String @id @default(cuid())
  tradesmanId String
  title       String
  imageUrl    String

  tradesman Tradesman @relation(fields: [tradesmanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tradesmanId])
}

model Job {
  id                String    @id @default(cuid())
  jobId             String    @unique
  customerId        String
  serviceType       String
  description       String?   @db.Text
  location          String
  city              String
  area              String
  preferredDate     DateTime?
  preferredTime     String?
  isFlexible        Boolean   @default(false)
  images            String[]
  status            JobStatus @default(PENDING)
  contactShared     Boolean   @default(false)
  isDirectRequest   Boolean   @default(false)
  targetTradesmanId String?
  acceptedCount     Int       @default(0)
  maxAcceptances    Int       @default(3)

  customer  Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  services  JobService[]
  responses JobResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([customerId])
  @@index([status])
  @@index([city])
  @@index([createdAt])
}

model JobService {
  id        String @id @default(cuid())
  jobId     String
  serviceId String

  job     Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([jobId, serviceId])
  @@index([jobId])
  @@index([serviceId])
}

model JobResponse {
  id             String    @id @default(cuid())
  jobId          String
  tradesmanId    String
  status         JobStatus @default(PENDING)
  notifiedAt     DateTime  @default(now())
  respondedAt    DateTime?
  reminderCount  Int       @default(0)
  lastReminderAt DateTime?
  creditDeducted Boolean   @default(false)

  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tradesman Tradesman @relation(fields: [tradesmanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, tradesmanId])
  @@index([jobId])
  @@index([tradesmanId])
  @@index([status])
}

model Review {
  id          String  @id @default(cuid())
  customerId  String
  tradesmanId String
  rating      Int
  comment     String? @db.Text
  jobId       String?

  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tradesman Tradesman @relation(fields: [tradesmanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tradesmanId])
  @@index([customerId])
}

model CreditTransaction {
  id             String  @id @default(cuid())
  tradesmanId    String
  amount         Int
  type           String
  description    String?
  balanceBefore  Int
  balanceAfter   Int
  paymentMethod  String?
  transactionRef String?

  tradesman Tradesman @relation(fields: [tradesmanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tradesmanId])
  @@index([createdAt])
}

model ContactMessage {
  id         String  @id @default(cuid())
  name       String
  email      String
  subject    String
  message    String  @db.Text
  isResolved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isResolved])
}

model FakeLeadReport {
  id          String  @id @default(cuid())
  tradesmanId String
  jobId       String
  reason      String  @db.Text
  isResolved  Boolean @default(false)
  refunded    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tradesmanId])
  @@index([isResolved])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model SiteSettings {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  updatedAt DateTime @updatedAt

  @@index([key])
}
